{
    "output": "eDP-1",
    "margin-top": 4,
    "margin-left": 4,
    "margin-right": 4,
    "margin-bottom": 0, 
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 0,
    "exclusive": true,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "mpris",
        "custom/mediactl",
        "pulseaudio",
        "battery",
        "tray"
    ],
    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true,
        "persistent-workspaces": {
            "*": 5
        }
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %B %d, %Y}",
        /* The missing piece for the calendar */
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month", // 'year' might be too big for a small bar, 'month' is usually safer
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#C0AAFF'><b>{}</b></span>",
                "days": "<span color='#ffffff'><b>{}</b></span>",
                "weeks": "<span color='#78DCE8'><b>W{}</b></span>",
                "weekdays": "<span color='#A9DC76'><b>{}</b></span>",
                "today": "<span color='#FF6188'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "mpris": {
        "format": "{player_icon} {title} - {artist}",
        "player-icons": {
            "default": "󰎆",
            "spotify": "",
            "firefox": "󰈹"
        },
        "status-icons": {
            "paused": "󰏤"
        },
        "on-click": "media-applet",
        "max-length": 40
    },
    "pulseaudio": {
        "format": "󰕾 {volume}%",
        "format-muted": "󰝟 Muted",
        "on-click": "pavucontrol"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": [
            "󰂎",
            "󰁺",
            "󰁼",
            "󰁾",
            "󰂀",
            "󰁹"
        ]
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10
    }
}