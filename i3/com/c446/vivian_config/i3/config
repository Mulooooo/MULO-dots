# i3 Configuration

# === BASIC SETTINGS ===
set $mod Mod4
floating_modifier $mod
font Monospace 15

# === VARIABLES ===
set $screen HDMI-1-0
set $screen2 eDP-1
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"
set $python_env $HOME/Documents/Github/SI--/.venv/bin/activate
set $SIPP $HOME/Documents/Github/SI--/SI.py

# Wallpapers
set $wallpaper_vivian1 $HOME/Pictures/vivian_bg_1.jpg
set $wallpaper_vivian2 $HOME/Pictures/vivian_bg_2.jpg
set $wallpaper_win $HOME/Pictures/bg_win.jpg

# === AUTOSTART ===
exec --no-startup-id setxkbmap fr
exec --no-startup-id xset s off
exec --no-startup-id xset -dpms
exec --no-startup-id xset s noblank
exec_always --no-startup-id xrandr --rate 60
exec_always --no-startup-id picom --config $HOME/.config/picom/picom.conf &
exec_always --no-startup-id mpd &
exec_always --no-startup-id dunst &
exec_always --no-startup-id pgrep -x polybar || polybar &
exec_always --no-startup-id battery &
exec_always --no-startup-id sudo update-alternatives --config x-cursor-theme
exec_always --no-startup-id gsettings set org.gnome.desktop.interface cursor-size 48
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id ~/.config/i3/battery_warning.sh
exec --no-startup-id light -I
exec vesktop

# === WINDOW RULES ===
for_window [class="numworks-omega"] floating enable
for_window [class="steam_app_0"] fullscreen enable
for_window [class=".*"] border pixel 2

# === APPEARANCE ===
client.focused          #C0AAFF #C0AAFF #1A1A1A #AB9DF2
client.unfocused        #403E5C #403E5C #8C8C8C #403E5C
client.focused_inactive #4F4364 #4F4364 #D1D1D1 #4F4364
client.urgent           #FF6188 #FF6188 #F2F2F2 #FF6188

assign [class="firefox"] 1
assign [class="vesktop"] 2
assign [class="Code"] 3
assign [class="Spotify"] 4

gaps inner 8
gaps outer 0
gaps top -8

bar {
    mode invisible
    tray_output none
}

# === KEY BINDINGS ===

# Basic controls
bindsym $mod+Return exec kitty
bindsym $mod+Shift+c kill
bindsym $mod+l exec i3lock-fancy
bindsym $mod+e exec thunar
bindsym $mod+s exec --no-startup-id rofi -show drun
bindsym $mod+a exec --no-startup-id rofi -show window

# Focus movement
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+semicolon focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Window movement
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Workspace navigation
bindsym $mod+Tab workspace next
bindsym $mod+Shift+Tab workspace prev
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Layout controls
bindsym $mod+h split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+q layout stacking
bindsym $mod+Shift+a layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Custom Python scripts
bindsym $mod+w exec --no-startup-id source $python_env && python $SIPP --mode text
bindsym $mod+x exec --no-startup-id source $python_env && python $SIPP --mode set_start
bindsym $mod+c exec --no-startup-id source $python_env && python $SIPP --mode vision

# Display management
bindsym $mod+m exec --no-startup-id xrandr --setprovideroutputsource 1 0 && xrandr --output eDP-1 --primary --mode 2560x1600 --pos 0x0 --rotate normal --output HDMI-1-0 --mode 1920x1080 --right-of eDP-1 --rotate normal
bindsym $mod+Shift+m exec --no-startup-id xrandr --output eDP-1 --auto --output HDMI-1-0 --auto --same-as eDP-1
bindsym $mod+Shift+b exec --no-startup-id xrandr --setprovideroutputsource 1 0 && xrandr --output $screen --rotate left --output $screen2 --rotate left
bindsym $mod+Shift+v exec --no-startup-id xrandr --setprovideroutputsource 1 0 && xrandr --output $screen --rotate right --output $screen2 --rotate right

# Wallpaper switching
bindsym $mod+b exec --no-startup-id feh --bg-fill $wallpaper_vivian1
bindsym $mod+Shift+w exec --no-startup-id feh --bg-fill $wallpaper_win

# Screenshots
bindsym $mod+Shift+s exec ~/screenshot.sh
bindsym Print exec flameshot gui

# Polybar
bindsym $mod+p exec polybar -c /etc/polybar/config.ini
bindsym $mod+o exec killall -q polybar

# Audio
bindsym XF86AudioRaiseVolume exec --no-startup-id bash -c 'pactl set-sink-volume @DEFAULT_SINK@ +5% && ~/.config/i3/notify-volume.sh'
bindsym XF86AudioLowerVolume exec --no-startup-id bash -c 'pactl set-sink-volume @DEFAULT_SINK@ -5% && ~/.config/i3/notify-volume.sh'
bindsym XF86AudioMute exec --no-startup-id bash -c 'pactl set-sink-mute @DEFAULT_SINK@ toggle && ~/.config/i3/notify-volume.sh'

# Brightness
bindsym XF86MonBrightnessUp exec --no-startup-id bash -c 'brightnessctl set +5% && ~/.config/i3/notify-brightness.sh'
bindsym XF86MonBrightnessDown exec --no-startup-id bash -c 'brightnessctl set 5%- && ~/.config/i3/notify-brightness.sh'
bindsym Ctrl+F7 exec brightness_hdmi down
bindsym Ctrl+F8 exec brightness_hdmi up

# Screen
bindsym XF86ScreenSaver exec xset dpms force off

# Terminal shortcuts
bindsym Ctrl+F1 exec --no-startup-id alacritty
bindsym Ctrl+F5 exec --no-startup-id kitty
bindsym Ctrl+F2 exec --no-startup-id dmenu_run

# Power profiles
bindsym $mod+F1 exec --no-startup-id systemctl start platform-profile@performance
bindsym $mod+F2 exec --no-startup-id systemctl start platform-profile@quiet
bindsym $mod+F3 exec --no-startup-id systemctl start platform-profile@auto

# Microphone
bindsym Ctrl+F3 exec amixer set Capture nocap && dunstify -a "Microphone" "Microphone" "Microphone is muted" -r 100 -i /usr/local/bin/icons/mic-off.svg
bindsym Ctrl+F4 exec amixer set Capture cap && dunstify -a "Microphone" "Microphone" "Microphone is unmuted" -r 100 -i /usr/local/bin/icons/mic.svg

# Touchpad
bindsym Ctrl+F9 exec xinput set-prop $(xinput list | grep -oP 'Touchpad.*id=\K\d+') "Device Enabled" 0 && dunstify -a "Touchpad" "Touchpad" "Touchpad is disabled" -r 100
bindsym Ctrl+F10 exec xinput set-prop $(xinput list | grep -oP 'Touchpad.*id=\K\d+') "Device Enabled" 1 && dunstify -a "Touchpad" "Touchpad" "Touchpad is enabled" -r 100

# i3 session management
bindsym $mod+t exec --no-startup-id i3-resurrect restore
bindsym $mod+y exec --no-startup-id i3-resurrect save
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

# === MODES ===

# Resize mode
mode "resize" {
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym l resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt
    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# Gaps modes
set $mode_gaps Gaps: (o) outer, (i) inner
set $mode_gaps_outer Outer Gaps: +|-|0 (local), Shift + +|-|0 (global)
set $mode_gaps_inner Inner Gaps: +|-|0 (local), Shift + +|-|0 (global)
bindsym $mod+g mode "$mode_gaps"

mode "$mode_gaps" {
    bindsym o mode "$mode_gaps_outer"
    bindsym i mode "$mode_gaps_inner"
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

mode "$mode_gaps_inner" {
    bindsym plus gaps inner current plus 5
    bindsym minus gaps inner current minus 5
    bindsym 0 gaps inner current set 0
    bindsym Shift+plus gaps inner all plus 5
    bindsym Shift+minus gaps inner all minus 5
    bindsym Shift+0 gaps inner all set 0
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

mode "$mode_gaps_outer" {
    bindsym plus gaps outer current plus 5
    bindsym minus gaps outer current minus 5
    bindsym 0 gaps outer current set 0
    bindsym Shift+plus gaps outer all plus 5
    bindsym Shift+minus gaps outer all minus 5
    bindsym Shift+0 gaps outer all set 0
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
